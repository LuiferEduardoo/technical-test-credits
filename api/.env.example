# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mydatabase
DB_USER=user
DB_PASSWORD=userpassword

# Database Root (for administrative tasks)
DB_ROOT_PASSWORD=rootpassword

# JWT
JWT_SECRET=your_super_secret_key_change_this_in_production_please
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Brevo SMTP Configuration
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_LOGIN=brevo_login
BREVO_EMAIL=brevo_email
BREVO_SMTP_KEY=brevo_smtp_key
